{
  "name": "BEAM",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "db:up": "docker compose -f db.docker-compose.yaml up -d --build",
    "db:down": "docker compose -f db.docker-compose.yaml down && docker compose -f db.docker-compose.yaml rm -f",
    "db:generate": "drizzle-kit generate",
    "migrate": "tsx --env-file=.env server/db/migrate.ts",
    "seed": "tsx --env-file=.env server/db/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.700.0",
    "drizzle-orm": "^0.36.4",
    "nuxt": "^4.4.4",
    "postgres": "^3.4.5",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2"
  }
}
