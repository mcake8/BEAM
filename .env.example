# Database
# Used directly for local dev (npm run dev/migrate/seed).
DATABASE_URL=postgres://beam:beam@localhost:5432/beam

# Postgres credentials — required by docker-compose (it builds DATABASE_URL
# from these and points it at the `postgres` service).
POSTGRES_USER=beam
POSTGRES_PASSWORD=beam
POSTGRES_DB=beam

# Auth — session cookie encryption secret (min 32 chars) + admin password
AUTH_SECRET=change-me-to-a-long-random-string-min-32-chars
ADMIN_PASSWORD=change-me

# S3 / MinIO
# S3_ENDPOINT: used for local dev. In docker-compose the app talks to the
# internal `minio` service, so S3_ENDPOINT there is fixed to http://minio:9000.
S3_ENDPOINT=http://localhost:9000
# S3_PUBLIC_URL: base URL for image links, must be reachable from the browser.
S3_PUBLIC_URL=http://localhost:9000
S3_BUCKET=beam-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
